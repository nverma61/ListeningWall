{
  "name": "listening-wall",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev -p 3000 -H 0.0.0.0",
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\"",
    "kill:3000": "sh -c 'for p in $(lsof -ti :3000 2>/dev/null); do kill \"$p\" 2>/dev/null; done; exit 0'",
    "dev:clean": "npm run kill:3000 && npm run clean:next && next dev -p 3000 -H 0.0.0.0",
    "dev:poll": "WATCHPACK_POLLING=1 next dev -p 3000 -H 0.0.0.0",
    "build": "next build && node scripts/verify-css-build.mjs",
    "verify:css": "node scripts/verify-css-build.mjs",
    "start": "next start",
    "lint": "next lint",
    "db:types": "supabase gen types typescript --local > lib/types/database.gen.ts 2>/dev/null || echo 'Run with Supabase CLI linked'",
    "seed": "npx tsx scripts/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@tanstack/react-query": "^5.62.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "next": "14.2.35",
    "next-themes": "^0.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
